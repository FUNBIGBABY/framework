# Server Configuration
HOST=0.0.0.0
PORT=9900
DEBUG=True
JWT_SECRET_KEY=
DATABASE_URL=postgresql+psycopg://framework:change-me@localhost:5432/framework
POSTGRES_DB=framework
POSTGRES_USER=framework
POSTGRES_PASSWORD=change-me

# CORS Configuration
FRONTEND_URL=http://localhost:5173
APP_BASE_DOMAIN=
APP_NAME=Personal AI Framework Studio
SUPER_ADMIN_EMAIL=
ALLOWED_EMAILS=
ENABLE_PUBLIC_REGISTER=false

# Storage Paths
STORAGE_PATH=./storage
UPLOAD_PATH=./storage/uploads
FRAMEWORKS_PATH=./storage/frameworks

# LLM Provider Configuration
LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_DEFAULT=deepseek-v4-flash
DEEPSEEK_MODEL_REASONING=deepseek-v4-pro
DEEPSEEK_THINKING_MODE=false
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Legacy llm_local/Ollama/GCP path is disabled by default.
# Do not enable unless intentionally testing the old code path.
ENABLE_LEGACY_LLM=false

# Vector Store Provider Configuration
VECTORSTORE_PROVIDER=pgvector
OPENAI_VECTOR_STORE_ENABLED=false
OPENAI_VECTOR_STORE_API_KEY=
OPENAI_VECTOR_STORE_LIBRARY=
OPENAI_VECTOR_STORE_ACTIVITY=

# Embedding Provider Configuration
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
DASHSCOPE_API_KEY=

# Object Store Provider Configuration
OBJECT_STORE_PROVIDER=minio
OBJECT_STORE_ENDPOINT=
OBJECT_STORE_BUCKET=
OBJECT_STORE_ACCESS_KEY=
OBJECT_STORE_SECRET_KEY=

# File Upload Limits
MAX_FILE_SIZE_MB=2
MAX_TEXT_LENGTH=10000
